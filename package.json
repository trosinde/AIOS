{
  "name": "aios",
  "version": "0.1.0",
  "description": "AI Orchestration System – Dynamische Workflow-Orchestrierung",
  "type": "module",
  "bin": {
    "aios": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:integration": "vitest run '**/*.integration.test.ts'",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench --run src/core/knowledge-bus.bench.ts",
    "perf:kb:scale": "tsx scripts/perf/knowledge-bus-scale.ts",
    "perf:kb:check": "tsx scripts/perf/compare-baseline.ts perf-baseline.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@lancedb/lancedb": "0.27.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^11.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "ora": "^8.1.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
